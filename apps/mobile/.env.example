# Mobile app should call public HTTP APIs only.
# Local simulator development can use http://localhost:3000, but release builds must use a public HTTPS origin.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# 모바일 앱 변형: anonymous(익명친구) | card(카드서비스)
EXPO_PUBLIC_MOBILE_VARIANT=anonymous

# 익명친구 앱에서 전화번호 인증 스킵 여부(기본값 true)
EXPO_PUBLIC_SKIP_ANONYMOUS_CHAT_PHONE_AUTH=true
