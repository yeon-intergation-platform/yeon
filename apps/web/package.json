{
  "name": "@yeon/web",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "predev": "rm -f .next/dev/trace .next/dev/trace-turbopack",
    "dev": "drizzle-kit migrate --config=drizzle.config.ts && next dev",
    "build": "next build",
    "lint": "eslint src --ext .ts,.tsx",
    "start": "next start",
    "start:standalone": "node scripts/start-standalone.mjs",
    "prod:local": "pnpm build && pnpm start:standalone",
    "openai:test": "tsx scripts/test-openai-chat.ts",
    "r2:test": "tsx scripts/test-r2-storage.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "db:check:drift": "node scripts/check-schema-drift.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:typing-room": "RUN_TYPING_ROOM_ONLINE_E2E=1 playwright test e2e/typing-room-online.spec.ts --project=chromium",
    "e2e:typing-room:check": "playwright test e2e/typing-room-online.spec.ts --project=chromium"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/lib-storage": "^3.1025.0",
    "@colyseus/sdk": "^0.17.42",
    "@cyntler/react-doc-viewer": "^1.17.1",
    "@node-rs/argon2": "^2.0.2",
    "@sentry/nextjs": "^10.48.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.74",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/dompurify": "^3.2.0",
    "@uiw/react-markdown-preview": "^5.2.0",
    "@uiw/react-md-editor": "^4.1.0",
    "@yeon/api-client": "workspace:*",
    "@yeon/api-contract": "workspace:*",
    "@yeon/domain": "workspace:*",
    "@yeon/race-shared": "workspace:*",
    "@yeon/typing-race-engine": "workspace:*",
    "docx": "^9.6.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "heic2any": "^0.0.4",
    "idb": "^8.0.3",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "pdf-parse": "1.1.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-joyride": "^3.0.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.2",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@yeon/config": "workspace:*",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
