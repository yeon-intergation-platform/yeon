# Web-only secrets
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# ── OpenAI API ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# 녹음 AI 대화 / 멘토링 요약 (텍스트 생성)
# 권장: gpt-4.1-mini (비용 효율), gpt-4.1 (고품질), gpt-5.4-medium (최고급)
OPENAI_AI_CHAT_MODEL=gpt-4.1-mini

# 파일 가져오기 - 스프레드시트 분석 (엑셀 → 수강생 추출)
# 설정 안 하면 OPENAI_AI_CHAT_MODEL 사용
# 권장: gpt-4.1-mini (저렴 + 텍스트 정확도 우수)
OPENAI_AI_IMPORT_MODEL=gpt-4.1-mini

# 파일 가져오기 - 이미지 분석 (이미지 → 수강생 추출, Vision 지원 모델 필수)
# 설정 안 하면 OPENAI_AI_IMPORT_MODEL → OPENAI_AI_CHAT_MODEL 순으로 폴백
# 권장: gpt-4.1-nano (가장 저렴, Vision 지원)
OPENAI_AI_VISION_MODEL=gpt-4.1-nano

# 녹음 전사 (Whisper 계열)
# 권장: gpt-4o-transcribe-diarize (화자 분리 포함)
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize

# 전사 실패 시 폴백 모델 (쉼표 구분, 순서대로 시도)
OPENAI_TRANSCRIPTION_FALLBACK_MODELS=gpt-4o-transcribe
# ────────────────────────────────────────────────────────────────────────────

# Cloudflare R2 (음성 파일 저장)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

COUNSELING_RECORDS_WORK_DIR=
ENABLE_CHAT_SERVICE_DEMO_SEED=false

# Google Sheets 연동 (서비스 계정 JSON을 한 줄로)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Microsoft OneDrive 연동
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Google Search Console 도메인 소유권 확인
GOOGLE_SITE_VERIFICATION=

# ── Bugsink/Sentry 오류 추적 ─────────────────────────────────────────────────
# Bugsink는 Sentry SDK 호환이므로 Bugsink 프로젝트 DSN을 여기에 넣는다.
BUGSINK_DSN=
NEXT_PUBLIC_BUGSINK_DSN=
# 기존 Sentry SaaS를 계속 쓸 때만 사용한다. BUGSINK_DSN이 우선한다.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Sentry SaaS 소스맵 업로드용. Bugsink만 쓰면 필수값이 아니다.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# ─────────────────────────────────────────────────────────────────────────────

# Public values exposed to the browser
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PULL-IT revival reverse-proxy origins (no trailing slash)
PULLIT_FRONTEND_ORIGIN=
PULLIT_BACKEND_ORIGIN=
PULLIT_DOCS_ORIGIN=

# 타자 레이스 실시간 WebSocket 서버 (Colyseus)
# dev: ws://localhost:2567, prod: wss://race.yeon.world 등
# Spring bootstrap backend smoke route base URL
SPRING_BOOTSTRAP_BASE_URL=http://127.0.0.1:8081
SPRING_BACKEND_BASE_URL=http://127.0.0.1:8081
SPRING_INTERNAL_TOKEN=

NEXT_PUBLIC_RACE_SERVER_URL=ws://localhost:2567

# ── Resend 이메일 발송 ──────────────────────────────────────────────────────
# 일반 로그인(이메일+비밀번호) 가입 이메일 인증 · 비밀번호 재설정 메일 발송에 사용
# 발급: https://resend.com/api-keys
RESEND_API_KEY=
# 발신 주소 (노-리플라이). prod 에서는 DNS 인증된 도메인으로 교체
RESEND_FROM_ADDRESS=noreply@yeon.world
# ─────────────────────────────────────────────────────────────────────────────

# ── Aligo SMS (chat-service 전화번호 인증) ───────────────────────────────────
# 발급/문서: https://smartsms.aligo.in/admin/api/info.html
# sender 는 알리고에 사전 등록된 발신번호여야 합니다.
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=
# true 이면 알리고 testmode_yn=Y 로 호출되어 실제 발송/과금 없이 연동만 검증합니다.
ALIGO_TEST_MODE=false
# ─────────────────────────────────────────────────────────────────────────────

# ── GameMonetize 게임 허브 Feed (game.yeon.world) ────────────────────────────
# 게임 허브(features/game-service)가 서버에서 캐싱 fetch 하는 GameMonetize Feed URL.
# 미설정 시 표준 public feed 로 동작한다. category=All / company=All 파라미터는
# 빈 배열을 반환하므로 넣지 않는다(수집 후 카테고리 필터). format=0 이 JSON.
# 예: https://gamemonetize.com/feed.php?format=0&page=1&type=html5&amount=200
GAMEMONETIZE_FEED_URL=
# ─────────────────────────────────────────────────────────────────────────────
