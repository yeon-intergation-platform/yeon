# dependencies
node_modules/
/.pnp
.pnp.js
.pnpm-store/

# python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# testing
coverage/

# next.js
.next/
out/
apps/*/.next/

# production
build/
dist/
apps/*/dist/
packages/*/dist/

# misc
.DS_Store
*.pem
.turbo/
.expo/
AGENTS.local.md
apps/*/.expo
expo-env.d.ts
web-build/
apps/web/.data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright auth state
e2e/.auth/session.json
apps/web/e2e/.auth/

# OMC state
.omc/
apps/web/.omc/

# Playwright test results
test-results/
apps/web/test-results/

# Worktree artifacts
apps/web/apps/

