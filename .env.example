# Local development only.
# Do not copy this file to /srv/yeon or use it as a production secret source.
# Production names and delivery rules: docs/deployment/production-runtime-secrets.md

NODE_ENV=development
PORT=3000
WEB_PORT=3000
BACKEND_PORT=8081
RACE_SERVER_PORT=2567
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_ROOM_VOICE_CALL=false
ROOM_VOICE_CALL_ENABLED=false

# Local authentication and service-to-service signing
AUTH_SECRET=change-me-local-auth-secret
SPRING_INTERNAL_TOKEN=change-me-local-internal-token
TYPING_RACE_SEED_SECRET=change-me-local-race-seed
SPRING_PROFILES_ACTIVE=dev.local

# Local OAuth provider credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Local AI integrations
OPENAI_API_KEY=
OPENAI_AI_CHAT_MODEL=gpt-4.1-mini
OPENAI_AI_IMPORT_MODEL=gpt-4.1-mini
OPENAI_AI_VISION_MODEL=gpt-4.1-nano
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_TRANSCRIPTION_FALLBACK_MODELS=gpt-4o-transcribe
ZAI_API_KEY=
ZAI_BASE_URL=
ZAI_GRADING_MODEL=

# Local object storage
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Local observability
BUGSINK_DSN=
NEXT_PUBLIC_BUGSINK_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Local PostgreSQL. DATABASE_URL remains a local/test compatibility input for
# pnpm dev:all. Production stores only POSTGRES_PASSWORD as the secret SSOT and
# builds connection properties from non-secret POSTGRES_* values.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=yeon
POSTGRES_USER=yeon
POSTGRES_PASSWORD=change-me-local-db-password
DATABASE_URL=postgresql://yeon:change-me-local-db-password@127.0.0.1:5432/yeon

COUNSELING_RECORDS_WORK_DIR=
ENABLE_CHAT_SERVICE_DEMO_SEED=false
